# .env.example - bu faylni .env deb nomlang va to'ldiring

# MAJBURIY: Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# MAJBURIY: Admin telegram ID lari (vergul bilan ajrating)
# Telegram ID ni @userinfobot dan bilib olasiz
ADMIN_IDS=123456789,987654321,111222333

# IXTIYORIY: Backup uchun Telegram kanal ID si
# Kanal yarating, botni admin qiling, keyin kanal ID sini qo'shing
# Kanal ID sini bilish uchun: kanal habarini forward qiling @userinfobot ga
BACKUP_CHANNEL_ID=-1001234567890

# IXTIYORIY: Ma'lumotlar bazasi yo'li (default: joriy papkada)
DB_PATH=qarz_daftar.db
